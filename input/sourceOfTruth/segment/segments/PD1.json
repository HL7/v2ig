      {
        "id": "PD1.1-livingDependency",
        "path": "PD1.1-livingDependency",
        "short": "Living Dependency",
        "definition": "This field identifies specific living conditions (e.g., spouse dependent on patient, walk-up) that are relevant to an evaluation of the patient's healthcare needs. This information can be used for discharge planning. This field repeats because, for example, \"spouse dependent\" and \"medical supervision required\" can apply at the same time. Refer to {{v2-table:0223:Living Dependency}} in Chapter 2C, Code Tables, for suggested values.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 755
          }
        ],
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "CWE"
          }
        ],
        "binding": {
          "strength": "required",
          "valueSet": "http://terminology.hl7.org/ValueSet/v2-0223"
        },
        "extension": [
          {
            "url": "http://hl7.org/v2/StructureDefinition/optionality",
            "valueCode": "O"
          }
        ]
      },
      {
        "id": "PD1.2-livingArrangement",
        "path": "PD1.2-livingArrangement",
        "short": "Living Arrangement",
        "definition": "This field identifies the situation in which the patient lives at his residential address. Examples might include Alone, Family, Relatives, Institution, etc. Refer to {{v2-table:0220:Living Arrangement}} in Chapter 2C, Code Tables, for suggested values.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 742
          }
        ],
        "min": 0,
        "max": 1,
