            "url": "http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status",
            "valueCode": "withdrawn"
          }
        ]
      },
      {
        "id": "PD1.5-studentIndicator",
        "path": "PD1.5-studentIndicator",
        "short": "Student Indicator",
        "definition": "This field indicates if the patient is currently a student or not, and whether the patient is a full-time or a part-time student. This field does not indicate the student's degree level (high school, college, elementary) or the student's field of study (accounting, engineering, etc.). Refer to {{v2-table:0231:Student Status}} in chapter 2C, for suggested values.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 745
          }
        ],
        "min": 0,
        "max": 1,
