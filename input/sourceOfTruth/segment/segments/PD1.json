            "valueCode": "O"
          }
        ]
      },
      {
        "id": "PD1.9-separateBill",
        "path": "PD1.9-separateBill",
        "short": "Separate Bill",
        "definition": "This field specifies that charges for this patient are to be billed separately from other patient bills with the same guarantor. (This bill is now a patient bill rather than a guarantor bill.) Refer to {{v2-table:0136:Yes/No Indicator}} in Chapter 2C, Code Tables, for valid values.",
        "comment": "Y Bill separately\n\nN normal processing",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 761
          }
        ],
        "min": 0,
        "max": 1,
