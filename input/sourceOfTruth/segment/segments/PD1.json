            "valueCode": "O"
          }
        ]
      },
      {
        "id": "PD1.6-handicap",
        "path": "PD1.6-handicap",
        "short": "Handicap",
        "definition": "This field indicates the nature of the patient's permanent handicapped condition (e.g., deaf, blind). A handicapped condition is defined as a physical or mental disability that is permanent. Transient handicapped conditions should be sent in the ambulatory status. Refer to {{v2-table:0295:Handicap}} in Chapter 2C, Code Tables, for suggested values.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 753
          }
        ],
        "min": 0,
        "max": 1,
        "type": [
          {
            "code": "CWE"
          }
        ],
        "binding": {
          "strength": "required",
          "valueSet": "http://terminology.hl7.org/ValueSet/v2-0295"
        },
        "extension": [
          {
            "url": "http://hl7.org/v2/StructureDefinition/optionality",
            "valueCode": "O"
          }
        ]
      },
      {
        "id": "PD1.7-livingWillCode",
        "path": "PD1.7-livingWillCode",
        "short": "Living Will Code",
        "definition": "This field indicates whether or not the patient has a living will and, if so, whether a copy of the living will is on file at the healthcare facility. If the patient does not have a living will, the value of this field indicates whether the patient was provided information on living wills. Refer to {{v2-table:0315:Living Will Code}} in Chapter 2C, Code Tables, for suggested values. See also _PV2-43 - Living Will Code_.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 759
          }
        ],
        "min": 0,
        "max": 1,
        "type": [
          {
            "code": "CWE"
          }
