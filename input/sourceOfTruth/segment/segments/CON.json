            "valueCode": "O"
          }
        ]
      },
      {
        "id": "CON.11",
        "path": "CON.11",
        "short": "Consent Status",
        "definition": "Indicates whether consent has been sought and granted. For values see {{v2-table:0498:Consent Status}}.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 1786
          }
        ],
        "min": 1,
        "max": 1,
