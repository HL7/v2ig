            "url": "http://hl7.org/v2/StructureDefinition/optionality",
            "valueCode": "R"
          }
        ]
      },
      {
        "id": "LDP.3-locationService",
        "path": "LDP.3-locationService",
        "short": "Location Service",
        "definition": "This field contains the hospital or ancillary service with which this location is associated. Depends on institution use. Repeats for rooms that can be used, for example, by different services on different days. These values should match the values used for _PV1-10 - Hospital Service_, which is site defined. Refer to {{v2-table:0069:Hospital Service}} in Chapter 2C, Code Tables, for suggested values.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
            "code": 965
          }
        ],
        "min": 0,
        "max": 0,
