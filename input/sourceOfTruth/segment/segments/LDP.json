            "code": "PL"
          }
        ],
        "extension": [
          {
            "url": "http://hl7.org/v2/StructureDefinition/optionality",
            "valueCode": "R"
          }
        ]
      },
      {
        "id": "LDP.2-locationDepartment",
        "path": "LDP.2-locationDepartment",
        "short": "Location Department",
        "definition": "This field contains the institution's department to which this location belongs, or its cost center. Refer to {{v2-table:0264:Location Department}} in Chapter 2C, Code Tables, for suggested values.",
        "code": [
          {
            "system": "http://hl7.org/v2/CodeSystem/DataElements",
